{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,

    "allowJs": true,
    "checkJs": false,

    "isolatedModules": true,

    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx"

  },

  "include": ["src"]
}